{#
    A query to get the highest recent highlights from the highlights table.

    Parameters:
    - origin_key: The origin key to consider for data extraction.
    - days: The time interval (in days) to consider for recent highlights (default is 7 days).
    - limit: The maximum number of results to return (default is 5).
#}


WITH ath_multiple AS (
  SELECT *
  FROM public.highlights
  WHERE date > current_date - interval '{{ days }} days'
    AND origin_key = '{{ origin_key }}'
    AND type = 'ath_multiple'
),
ath_regular AS (
  SELECT *
  FROM public.highlights
  WHERE date > current_date - interval '{{ days }} days'
    AND origin_key = '{{ origin_key }}'
    AND type = 'ath_regular'
),
ath_multiple_since AS (
  SELECT *
  FROM public.highlights
  WHERE date > current_date - interval '{{ days }} days'
    AND origin_key = '{{ origin_key }}'
    AND type = 'ath_multiple_since'
),
ath_regular_since AS (
  SELECT *
  FROM public.highlights
  WHERE date > current_date - interval '{{ days }} days'
    AND origin_key = '{{ origin_key }}'
    AND type = 'ath_regular_since'
),
growth AS (
  SELECT *
  FROM public.highlights
  WHERE date > current_date - interval '{{ days }} days'
    AND origin_key = '{{ origin_key }}'
    AND type ILIKE 'growth_%%'
    AND value > 0
  ORDER BY growth_pct_growth DESC
  LIMIT 2
),
lifetime AS (
  SELECT *
  FROM public.highlights
  WHERE date > current_date - interval '{{ days }} days'
    AND origin_key = '{{ origin_key }}'
    AND type ILIKE 'lifetime_%%'
    AND value > 0
),
combined AS (
  -- All-time variants outrank their _since counterparts: when both fire for the same
  -- metric/day, the per-metric rn=1 dedup keeps the all-time one; a _since-only high
  -- (beats the since-date baseline but not the all-time max) still surfaces.
  SELECT 1 AS prio, * FROM ath_multiple
  UNION ALL
  SELECT 2 AS prio, * FROM ath_multiple_since
  UNION ALL
  SELECT 3 AS prio, * FROM lifetime
  UNION ALL
  SELECT 4 AS prio, * FROM ath_regular
  UNION ALL
  SELECT 5 AS prio, * FROM ath_regular_since
  UNION ALL
  SELECT 6 AS prio, * FROM growth

),
ranked AS (
  SELECT
    c.*,
    ROW_NUMBER() OVER (
      PARTITION BY origin_key, metric_key
      ORDER BY prio asc, date desc, growth_pct_growth desc
    ) AS rn
  FROM combined c
)

SELECT date, metric_key, type, value, ath_prior_max, ath_next_threshold, growth_prior_value, growth_pct_growth
FROM ranked
WHERE rn = 1
ORDER BY date DESC, prio ASC
LIMIT {{ limit | default(5) }}